{
  "name": "pw-json-api",
  "type": "module",
  "version": "1.0.0",
  "description": "ProcessWire JSON API",
  "license": "MIT",
  "author": "Ville Fokke Saarivaara",
  "scripts": {
    "format": "prettier --write src/",
    "docs:dev": "vitepress dev docs",
    "llms": "node scripts/generate-llms-txt.mjs",
    "docs:build": "node scripts/generate-llms-txt.mjs && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,vue,html,json,md,php}": "prettier --write",
    "src/**/*.php": "vendor/bin/phpstan analyse --memory-limit 1G"
  },
  "devDependencies": {
    "@prettier/plugin-php": "0.24.0",
    "@vite-pwa/vitepress": "1.1.0",
    "@vue/tsconfig": "0.9.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "prettier": "3.8.1",
    "sass-embedded": "1.97.3",
    "vitepress": "1.6.4",
    "workbox-window": "7.4.0"
  }
}
